<div data-controller="search">
  <div class="row g-4">
    <!-- FILTER SIDEBAR -->
    <aside class="col-lg-3">
      <%= render "shared/filters",
             cinemas: @cinemas,
             languages: @languages,
             controller_name: "search" %>
    </aside>
    <!-- MAIN CONTENT -->
    <section class="col-lg-9">
      <!-- SEARCH -->
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <%= form_with url: movies_path,
                        method: :get,
                        class: "row g-2 align-items-center",
                        data: { target: "search.form" } do %>
            <div class="col-md-9">
              <select id="search-box"
                      multiple
                      name="query[]"
                      placeholder="Select Movie/Director Name"
                      data-controller="tom-select"
                      class="form-select">
                <option value="">Select Movie</option>
                <optgroup label="Movies">
                  <% @films.each do |film| %>
                    <option value="<%= film.name %>"><%= film.name %></option>
                  <% end %>
                </optgroup>
                <optgroup label="Directors">
                  <% @directors.each do |director| %>
                    <option value="<%= director %>"><%= director %></option>
                  <% end %>
                </optgroup>
              </select>
            </div>
            <div class="col-md-3 d-grid">
              <%= submit_tag "Search", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
      <!-- MOVIES GRID -->
      <div id="search-results">
        <div class="movie-grid">
          <% @movies.each do |movie| %>
            <%= render "shared/movie_poster_view", movie: movie %>
          <% end %>
        </div>
        <!-- PAGINATION -->
        <div class="d-flex justify-content-center mt-4">
          <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
        </div>
      </div>
    </section>
  </div>
</div>
