<% backdrop = nil %>
<% if @movie.backgrounds.present? %>
  <% first_bg = eval(@movie.backgrounds.first) rescue nil %>
  <% backdrop = "https://image.tmdb.org/t/p/w1280#{first_bg['file_path']}" if first_bg %>
<% end %>
<div class="movie-hero mb-5" style="background-image: url('<%= backdrop %>')">
  <div class="movie-hero-overlay">
    <div class="container">
      <div class="row align-items-end">
        <div class="col-md-3 text-center text-md-start mb-4 mb-md-0">
          <% if @movie.poster.present? %>
            <img src="<%= @movie.poster %>" class="movie-poster shadow-lg">
          <% else %>
            <div class="no-poster">
              <span><%= @movie.name %></span>
            </div>
          <% end %>
        </div>
        <div class="col-md-9 text-white">
          <h1 class="display-5 fw-bold"><%= @movie.name %></h1>
          <p class="lead mb-2">
            <%= @movie.year %> •
            <%= @movie.language %> •
            <%= @movie.runtime %> min
          </p>
          <p class="mb-2">
            <strong>Director:</strong> <%= @movie.director %>
          </p>
          <p class="mb-3">
            <strong>Cast:</strong>
            <%= @movie.cast.first(5).join(", ") %>
          </p>
          <p class="movie-overview">
            <%= @movie.description %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="container">
  <h3 class="mb-4">Showtimes</h3>
  <% @movie.cinemas.uniq.each do |cinema| %>
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white">
        <%= link_to cinema.name, cinema_path(cinema), class: "text-white text-decoration-none fw-semibold" %>
      </div>
      <div class="card-body">
        <% @movie.showings.where(cinema_id: cinema).sort_by(&:date).each do |day| %>
          <div class="mb-3">
            <div class="fw-bold mb-2">
              <%= day.date %>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <% day.times.each do |time| %>
                <span class="badge bg-secondary p-2">
                  <%= time %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <div class="mt-4">
    <%= link_to edit_movie_path(@movie), class: "btn btn-outline-secondary btn-sm" do %>
      Update Movie Data
    <% end %>
  </div>
</div>
