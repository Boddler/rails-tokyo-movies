<div id="movieCarousel" class="carousel slide carousel-fade shadow-lg rounded overflow-hidden" data-bs-ride="carousel">

  <div class="carousel-inner">

    <% @movie.backgrounds.each_with_index do |image, index| %>

      <div class="carousel-item <%= 'active' if index == 0 %>">

        <div class="carousel-image-wrapper">

          <%= image_tag "https://image.tmdb.org/t/p/original#{image['file_path']}",
            class: "d-block w-100",
            alt: "#{@movie.name} background" %>

          <div class="carousel-overlay"></div>

        </div>

      </div>

    <% end %>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#movieCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#movieCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>