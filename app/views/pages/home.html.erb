<%= render "shared/banner" %>
<div class="container my-5">
  <h2 class="text-center mb-5 text-gradient-primary">Things to Check Out!</h2>
  <div class="row g-4 justify-content-center">
    <% cards = [
      { img: "https://static.wixstatic.com/media/7fe4e3_0681efdc476f4ddc995c9f0141164789~mv2.jpg/v1/fill/w_640,h_426,al_c,q_80,usm_0.66_1.00_0.01,enc_auto/7fe4e3_0681efdc476f4ddc995c9f0141164789~mv2.jpg", title: "10+ Languages!", text: "Don't miss the chance to see a movie in your language!" },
      { img: "https://image.tmdb.org/t/p/original/roG0HIkYU9hjULjdifeO7If00rZ.jpg", title: "Classic movies", text: "See classic movies the way they were meant to be seen!" },
      { img: "https://www.gotokyo.org/en/spot/885/images/885_0789_1_1400x1100.jpg", title: "Cinemas with style!", text: "Support old cinemas and help keep Tokyo's vibrant cinema scene alive!" }
    ] %>
    <% cards.each do |card| %>
      <div class="col-sm-6 col-md-4">
        <div class="card h-100 shadow-sm rounded index-card hover-lift">
          <div class="poster-wrapper">
            <img src="<%= card[:img] %>"
                 class="card-img-top movie-poster-img"
                 alt="<%= card[:title] %>">
          </div>
          <div class="card-body text-center">
            <h4 class="card-title mb-2"><%= card[:title] %></h4>
            <p class="card-text"><%= card[:text] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
